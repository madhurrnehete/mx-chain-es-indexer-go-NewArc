{
  "index_patterns": [
    "mrv-anchored-proofs-*"
  ],
  "template": {
    "settings": {
      "number_of_replicas": 0,
      "number_of_shards": 3
    },
    "mappings": {
      "properties": {
        "txHash": {
          "type": "keyword"
        },
        "eventType": {
          "type": "keyword"
        },
        "reportId": {
          "type": "keyword"
        },
        "publicTenantId": {
          "type": "keyword"
        },
        "publicFarmId": {
          "type": "keyword"
        },
        "publicSeasonId": {
          "type": "keyword"
        },
        "publicProjectId": {
          "type": "keyword"
        },
        "reportHash": {
          "type": "keyword"
        },
        "hashAlgo": {
          "type": "keyword"
        },
        "canonicalization": {
          "type": "keyword"
        },
        "methodologyVersion": {
          "type": "long"
        },
        "anchoredAt": {
          "type": "long"
        },
        "evidenceManifestHash": {
          "type": "keyword"
        },
        "blockHash": {
          "type": "keyword"
        },
        "blockRound": {
          "type": "long"
        },
        "isFinalized": {
          "type": "boolean"
        },
        "shardID": {
          "type": "long"
        },
        "eventOrder": {
          "type": "long"
        },
        "timestamp": {
          "type": "date",
          "format": "epoch_second"
        },
        "timestampMs": {
          "type": "date",
          "format": "epoch_millis"
        }
      }
    }
  }
}
