{
  "index_patterns": [
    "drwa-token-policies-*"
  ],
  "template": {
    "settings": {
      "number_of_replicas": 0,
      "number_of_shards": 3
    },
    "mappings": {
      "properties": {
        "txHash": {
          "type": "keyword"
        },
        "tokenId": {
          "type": "keyword"
        },
        "eventType": {
          "type": "keyword"
        },
        "blockHash": {
          "type": "keyword"
        },
        "blockRound": {
          "type": "long"
        },
        "isFinalized": {
          "type": "boolean"
        },
        "shardID": {
          "type": "long"
        },
        "eventOrder": {
          "type": "long"
        },
        "policyId": {
          "type": "keyword"
        },
        "regulated": {
          "type": "boolean"
        },
        "globalPause": {
          "type": "boolean"
        },
        "strictAuditorMode": {
          "type": "boolean"
        },
        "whitePaperCid": {
          "type": "keyword"
        },
        "registrationStatus": {
          "type": "keyword"
        },
        "windDownInitiated": {
          "type": "boolean"
        },
        "tokenPolicyVersion": {
          "type": "long"
        },
        "timestamp": {
          "type": "date",
          "format": "epoch_second"
        },
        "timestampMs": {
          "type": "date",
          "format": "epoch_millis"
        }
      }
    }
  }
}
